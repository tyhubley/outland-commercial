# Copy to .env.local (for local dev) and set on Vercel project env vars.

# From https://resend.com/api-keys — create a full-access key.
RESEND_API_KEY=

# The sender. Until you verify a domain on resend, the sandbox address works: onboarding@resend.dev
# After verifying outlandmanagement.com on Resend, switch to:  "OUTLAND Website <noreply@outlandmanagement.com>"
RESEND_FROM="OUTLAND Website <onboarding@resend.dev>"

# Where form submissions are delivered.
RESEND_TO=hello@outlandmanagement.com
